<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    
    <!-- CVE-2024-7254: Protobuf-java parsing vulnerability
         Affects: protobuf-java 3.x through 4.27.0
         Status: Using latest stable version (4.34.0 from mysql-connector-j 9.6.0)
         Justification: Upgraded to 4.34.0 which is well beyond the affected versions.
         Original issue was in versions prior to 4.28.0.
         Reference: https://github.com/protocolbuffers/protobuf/security/advisories
         Reviewed: 2025-01-XX
    -->
    <suppress>
        <notes>Protobuf-java 4.34.0 is patched - well beyond CVE-2024-7254 affected versions</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf\-java@4\.(3[0-9]|[4-9][0-9])\..*$</packageUrl>
        <cve>CVE-2024-7254</cve>
    </suppress>
    
    <!-- CVE-2025-68161: Apache Log4j2 vulnerability
         Affects: log4j-core 2.x (specific versions)
         Status: Using 2.25.2 (transitive from JMH benchmarking plugin)
         CVSS: 4.8 (MEDIUM) - below our 7.0 threshold but reported
         Justification: Transitive dependency from JMH plugin for benchmarks module only.
         Not used in production code. JMH plugin has strict version constraint preventing upgrade.
         Risk: Low - only affects benchmark runs, not production data generation.
         Reviewed: 2025-01-XX
    -->
    <suppress>
        <notes>Low risk: log4j only used in benchmarks module via JMH plugin, not production code</notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-(api|core)@2\.25\..*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>
    
</suppressions>
