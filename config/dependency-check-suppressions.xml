<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
      SUPPRESSION POLICY
      ══════════════════
      Permanent suppressions are NEVER used. All entries carry an `until` expiry date.
      When the date passes OWASP DC re-flags the CVE automatically, forcing a fresh review.

      Review process when a suppression expires:
        1. Check if a fixed version has shipped — upgrade if so, remove suppression.
        2. If still no fix: re-assess risk, extend `until` by 90 days, update notes.
        3. If CVE does not actually affect this project: document why in notes, extend 90 days.
    -->

    <!-- ── Log4j ──────────────────────────────────────────────────────────────
         CVE-2025-68161 | log4j-api/core 2.25.2 (transitive from JMH plugin)
         We pin log4j to 2.26.0 everywhere else but JMH's `strictly` constraint
         prevents the override in the benchmarks module. Benchmarks are not
         deployed; risk is limited to developer machines running JMH.
         Next review: check for JMH plugin update that lifts the version constraint.
    -->
    <suppress until="2026-07-05">
        <notes>log4j 2.25.2 transitive from JMH plugin (benchmarks only); not in production runtime; JMH strict constraint prevents upgrade. Review: check JMH plugin release for loosened constraint.</notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-(api|core)@2\.25\..*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>

